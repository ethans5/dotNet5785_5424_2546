<Window x:Class="PL.Volunteer.VolunteerList"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:BO="clr-namespace:BO;assembly=BL"
        Title="Liste des Volontaires"
        WindowState="Maximized"
        Background="#f8f9fa"
        Loaded="Window_Loaded"
        Closed="Window_Closed">

    <Window.Resources>
        <!-- Définition locale de la ressource pour l'enum VolunteerSortField -->
        <ObjectDataProvider x:Key="VolunteerSortFields" MethodName="GetValues"
                            ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="BO:VolunteerSortField" />
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
    </Window.Resources>

    <Grid Margin="20">
        <!-- Définition de la grille -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <!-- En-tête et filtres -->
            <RowDefinition Height="*" />
            <!-- Tableau -->
        </Grid.RowDefinitions>

        <!-- En-tête avec titre et filtres -->
        <StackPanel Grid.Row="0" Orientation="Vertical" Margin="0,0,0,20">
            <TextBlock Text="Gestion des Volontaires" FontSize="32" FontWeight="Bold" Foreground="#2c3e50"
                       HorizontalAlignment="Center" />
            <Rectangle Height="2" Fill="#3498db" Margin="100,10,100,20" HorizontalAlignment="Stretch" />

            <!-- Filtrage -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="20,0,0,20">
                <!-- Filtrer par champ -->
                <StackPanel Orientation="Vertical" Margin="0,0,20,0">
                    <TextBlock Text="Filtrer par :" VerticalAlignment="Center" FontSize="16" Margin="0,0,0,5" />
                    <ComboBox ItemsSource="{Binding Source={StaticResource VolunteerSortFields}}"
                              SelectedValue="{Binding SelectedFilter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              Width="200" Margin="0,0,0,0" />
                </StackPanel>

                <!-- Statut actif/inactif -->
                <StackPanel Orientation="Vertical" Margin="0,0,20,0">
                    <TextBlock Text="Statut :" VerticalAlignment="Center" FontSize="16" Margin="0,0,0,5" />
                    <ComboBox Name="StatusComboBox" Width="200" Margin="0,0,0,0"
                              SelectedValue="{Binding SelectedStatus, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              SelectedValuePath="Tag">
                        <ComboBoxItem Content="Tous" Tag="{x:Null}" />
                        <ComboBoxItem Content="Actif" Tag="True" />
                        <ComboBoxItem Content="Inactif" Tag="False" />
                    </ComboBox>
                </StackPanel>

                <!-- Boutons d'action -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom">
                    <Button Content="Appliquer" Width="100" Height="30" Background="#2980b9" Foreground="White" 
                            Click="FilterButton_Click" Margin="0,0,10,0"/>
                    <Button Content="Réinitialiser" Width="120" Height="30" Background="#e74c3c" Foreground="White"
                            Click="ResetFilterButton_Click"/>
                </StackPanel>
            </StackPanel>
        </StackPanel>

        <!-- Tableau des Volontaires -->
        <Border Grid.Row="1" Background="White" CornerRadius="10" BorderBrush="#bdc3c7" BorderThickness="1">
            <StackPanel>
                <!-- Sous-titre -->
                <TextBlock Text="Liste des Volontaires" FontSize="20" FontWeight="SemiBold" Foreground="#7f8c8d"
                           Margin="20,10,0,10" />

                <!-- Tableau -->
                <DataGrid Name="VolunteerDataGrid" AutoGenerateColumns="False" CanUserAddRows="False"
                          IsReadOnly="True" SelectionMode="Single" Margin="20"
                          Background="White" BorderBrush="#dcdcdc" BorderThickness="1"
                          RowBackground="#ecf0f1" AlternatingRowBackground="#dfe6e9"
                          MouseDoubleClick="VolunteerDataGrid_MouseDoubleClick">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="*" />
                        <DataGridTextColumn Header="Nom" Binding="{Binding Name}" Width="2*" />
                        <DataGridCheckBoxColumn Header="Actif" Binding="{Binding IsActive}" Width="*" />
                        <DataGridTextColumn Header="Total Traités" Binding="{Binding Totaltreated}" Width="*" />
                        <DataGridTextColumn Header="Annulations" Binding="{Binding TotalSelfCancellation}" Width="*" />
                        <DataGridTextColumn Header="Expirés" Binding="{Binding TotalExpired}" Width="*" />
                        <DataGridTextColumn Header="ID Appel Actif" Binding="{Binding IdCall}" Width="*" />
                        <DataGridTextColumn Header="Type d'Appel" Binding="{Binding callType}" Width="2*" />

                        <!-- Colonne pour la suppression -->
                        <DataGridTemplateColumn Header="Supprimer" Width="Auto">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="🗑️" Background="Transparent" Foreground="Red" BorderThickness="0"
                                            ToolTip="Supprimer le volontaire" Click="DeleteVolunteerButton_Click"
                                            CommandParameter="{Binding Id}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Footer avec des boutons d'action -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,20,10">
                    <Button Content="Ajouter" Width="120" Height="40" Margin="10,0,0,0" Background="#2ecc71"
                            Foreground="White" FontWeight="Bold" Click="AddVolunteer_Click"/>
                    <Button Content="Rafraîchir" Width="120" Height="40" Margin="10,0,0,0" Background="#3498db"
                            Foreground="White" FontWeight="Bold" Click="RefreshButton_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>
