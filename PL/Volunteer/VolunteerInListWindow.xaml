<Window x:Class="PL.Volunteer.VolunteerList"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Liste des Volontaires" Height="600" Width="800" Background="#f5f5f5">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="671*"/>
            <ColumnDefinition Width="109*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Titre et Barre de Recherche -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10" Grid.ColumnSpan="2">
            <TextBlock Text="Liste des Volontaires" FontSize="24" FontWeight="Bold" Foreground="#333"
                       VerticalAlignment="Center" Margin="10,0" />
            <TextBox Name="SearchTextBox" Width="300" Height="30" Margin="20,0,0,0"
                     HorizontalAlignment="Left" VerticalAlignment="Center" 
                     TextChanged="SearchTextBox_TextChanged"/>
        </StackPanel>

        <!-- Tableau des Volontaires -->
        <DataGrid Name="VolunteerDataGrid" AutoGenerateColumns="False" CanUserAddRows="False"
                  IsReadOnly="True" SelectionMode="Single" Margin="0,10,0,10"
                  MouseDoubleClick="VolunteerDataGrid_DoubleClick" Grid.ColumnSpan="2">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="Nom" Binding="{Binding Name}" Width="200"/>
                <DataGridCheckBoxColumn Header="Actif" Binding="{Binding IsActive}" Width="75"/>
                <DataGridTextColumn Header="Total Traités" Binding="{Binding Totaltreated}" Width="100"/>
                <DataGridTextColumn Header="Annulations" Binding="{Binding TotalSelfCancellation}" Width="100"/>
                <DataGridTextColumn Header="Expirés" Binding="{Binding TotalExpired}" Width="100"/>
                <DataGridTextColumn Header="Type d'Appel" Binding="{Binding CallTypeDisplay}" Width="200"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Boutons d'Action -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Left" Margin="510,10,0,10" Grid.ColumnSpan="2">
            <Button Content="Ajouter un Volontaire" Width="150" Height="40" Margin="5"
                    Background="#2ecc71" Foreground="White" FontWeight="Bold"
                    Click="AddVolunteer_Click"/>
            <Button Content="Rafraîchir" Width="100" Height="40" Margin="5"
                    Background="#3498db" Foreground="White" FontWeight="Bold"
                    Click="RefreshButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
