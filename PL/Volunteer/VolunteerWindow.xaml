<Window x:Class="PL.Volunteer.VolunteerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Volunteer Management"
        WindowState="Maximized"
        Width="1100" Height="700"
        Background="#F4F4F4">

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2.5*" />
            <ColumnDefinition Width="3.5*" />
        </Grid.ColumnDefinitions>

        <!-- Partie Gauche : Liste des appels disponibles -->
        <Border Grid.Column="0" Background="White" Padding="15" CornerRadius="10" BorderBrush="LightGray" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="📞 Appels disponibles" FontSize="20" FontWeight="Bold" Foreground="#333" Margin="0,0,0,10"/>

                <TextBlock x:Name="NoCallsMessage" Text="Aucun appel disponible" Visibility="Collapsed"
                           FontStyle="Italic" Foreground="Gray" HorizontalAlignment="Center"/>

                <ListBox x:Name="CallsListBox"
                         DisplayMemberPath="Description"
                         BorderBrush="LightGray"
                         BorderThickness="1"
                         Background="#FAFAFA"
                         Height="500"/>
            </StackPanel>
        </Border>

        <!-- Partie Droite : Informations du Volontaire -->
        <Border Grid.Column="1" Background="White" Padding="30" CornerRadius="10" BorderBrush="LightGray" BorderThickness="1" Margin="20,0,0,0">
            <StackPanel>
                <TextBlock Text="👤 Informations du Volontaire" FontSize="22" FontWeight="Bold" Foreground="#333" Margin="0,0,0,15"/>

                <!-- Mise en forme améliorée du formulaire -->
                <Grid Width="500">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="340"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Nom :" FontWeight="Bold" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center"/>
                    <TextBox x:Name="VolunteerNameTextBox" Grid.Row="0" Grid.Column="1" Margin="5" Width="320" Height="30" IsReadOnly="True" Background="#FAFAFA"/>

                    <TextBlock Text="Téléphone :" FontWeight="Bold" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center"/>
                    <TextBox x:Name="VolunteerPhoneTextBox" Grid.Row="2" Grid.Column="1" Margin="5" Width="320" Height="30" IsReadOnly="True" Background="#FAFAFA"/>

                    <TextBlock Text="Mot de Passe :" FontWeight="Bold" Grid.Row="4" Grid.Column="0" VerticalAlignment="Center"/>
                    <PasswordBox x:Name="VolunteerPasswordTextBox" Grid.Row="4" Grid.Column="1" Margin="5" Width="320" Height="30" IsEnabled="False" Background="#FAFAFA"/>

                    <TextBlock Text="Adresse :" FontWeight="Bold" Grid.Row="6" Grid.Column="0" VerticalAlignment="Center"/>
                    <TextBox x:Name="VolunteerAddressTextBox" Grid.Row="6" Grid.Column="1" Margin="5" Width="320" Height="30" IsReadOnly="True" Background="#FAFAFA"/>

                    <TextBlock Text="Email :" FontWeight="Bold" Grid.Row="8" Grid.Column="0" VerticalAlignment="Center"/>
                    <TextBox x:Name="VolunteerEmailTextBox" Grid.Row="8" Grid.Column="1" Margin="5" Width="320" Height="30" IsReadOnly="True" Background="#FAFAFA"/>

                    <TextBlock Text="Distance Max :" FontWeight="Bold" Grid.Row="10" Grid.Column="0" VerticalAlignment="Center"/>
                    <TextBox x:Name="MaxDistanceTextBox" Grid.Row="10" Grid.Column="1" Margin="5" Width="320" Height="30" Background="#FAFAFA" IsReadOnly="True"/>

                    <TextBlock Text="Type de Distance :" FontWeight="Bold" Grid.Row="12" Grid.Column="0" VerticalAlignment="Center"/>
                    <ComboBox x:Name="DistanceTypeComboBox" Grid.Row="12" Grid.Column="1" Margin="5" Width="320" Height="30" Background="#FAFAFA" IsEnabled="False">
                        <ComboBoxItem Content="aerial" Tag="aerial"/>
                        <ComboBoxItem Content="walking" Tag="walking"/>
                        <ComboBoxItem Content="driving" Tag="driving"/>
                    </ComboBox>

                    <TextBlock Text="Status :" FontWeight="Bold" Grid.Row="14" Grid.Column="0" VerticalAlignment="Center"/>
                    <CheckBox x:Name="IsActiveCheckBox" Grid.Row="14" Grid.Column="1" Margin="5" Width="320" IsEnabled="False"/>

                    <!-- 📊 Statistiques -->
                    <TextBlock Text="📊 Statistiques :" FontWeight="Bold" Grid.Row="16" Grid.Column="0" VerticalAlignment="Center"/>
                    <Grid Grid.Row="16" Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock x:Name="TotalTreatedText" Text="✔️ Total Traités: 0" FontSize="14" Foreground="Black" Grid.Row="0" Margin="5"/>
                        <TextBlock x:Name="TotalCancelledText" Text="❌ Total Annulés: 0" FontSize="14" Foreground="Black" Grid.Row="1" Margin="5"/>
                        <TextBlock x:Name="TotalExpiredText" Text="⏳ Total Expirés: 0" FontSize="14" Foreground="Black" Grid.Row="2" Margin="5"/>
                    </Grid>

                    <TextBlock Text="📞 Appel en cours :" FontWeight="Bold" Grid.Row="18" Grid.Column="0"/>
                    <TextBlock x:Name="CallInProgressText" Grid.Row="18" Grid.Column="1" Text="Aucun appel en cours" FontStyle="Italic" Foreground="Gray"/>
                </Grid>

                <!-- Boutons alignés -->
                <StackPanel Orientation="Vertical" HorizontalAlignment="Center" Margin="10,30,0,0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Content="✏️ Modifier" x:Name="EditButton" Width="160" Height="45" Margin="5" Background="#FFD700" Foreground="Black" FontWeight="Bold"/>
                        <Button Content="✅ Choisir Call" x:Name="AssignCallButton" Width="160" Height="45" Margin="5" Background="#28A745" Foreground="White" FontWeight="Bold"/>
                        <Button Content="📜 Voir les anciens appels" x:Name="ViewOldCallsButton" Width="160" Height="45" Margin="5" Background="#FF6347" Foreground="White" FontWeight="Bold"/>

                    </StackPanel>

                    <Button Content="❌ Fermer" x:Name="CloseButton" Width="340" Height="45" Margin="10,10,0,0" Background="#DC3545" Foreground="White" FontWeight="Bold"/>
                </StackPanel>
            </StackPanel>

        </Border>
    </Grid>
</Window>