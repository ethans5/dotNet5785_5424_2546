<Window x:Class="PL.Volunteer.VolunteerDetails"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Détails du Volontaire" WindowState="Maximized" Background="#f5f5f5">
    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*" />
            <!-- Colonne gauche -->
            <ColumnDefinition Width="1*" />
            <!-- Colonne droite -->
        </Grid.ColumnDefinitions>

        <!-- Colonne gauche -->
        <Border Grid.Column="0" Background="White" Padding="20" BorderBrush="#bdc3c7" BorderThickness="1" CornerRadius="10" Margin="10">
            <StackPanel>
                <!-- Titre -->
                <TextBlock Text="Identité et Contact" FontSize="24" FontWeight="Bold" Foreground="#2c3e50" Margin="0,0,0,20" />

                <!-- Section Identité -->
                <TextBlock Text="ID :" FontWeight="SemiBold" Margin="0,5" Foreground="#34495e" />
                <TextBox Name="IdTextBox" Margin="0,5" Height="30" IsEnabled="False" Background="#ecf0f1" />

                <TextBlock Text="Nom :" FontWeight="SemiBold" Margin="0,5" Foreground="#34495e" />
                <TextBox Name="NameTextBox" Margin="0,5" Height="30" Background="#ecf0f1" />

                <TextBlock Text="Mot de passe :" FontWeight="SemiBold" Margin="0,5" Foreground="#34495e" />
                <Grid Margin="0,5">
                    <PasswordBox Name="PasswordBox" Visibility="Visible" Margin="0,0,40,0" Height="30" Background="#ecf0f1" />
                    <TextBox Name="PasswordTextBox" Visibility="Collapsed" Margin="0,0,40,0" Height="30" Background="#ecf0f1" />
                    <Button Content="👁️" Width="30" Height="30" HorizontalAlignment="Right"
                            Click="TogglePasswordVisibility_Click" />
                </Grid>

                <TextBlock Text="Téléphone :" FontWeight="SemiBold" Margin="0,5" Foreground="#34495e" />
                <TextBox Name="PhoneTextBox" Margin="0,5" Height="30" Background="#ecf0f1" />

                <TextBlock Text="Email :" FontWeight="SemiBold" Margin="0,5" Foreground="#34495e" />
                <TextBox Name="MailTextBox" Margin="0,5" Height="30" Background="#ecf0f1" />
            </StackPanel>
        </Border>

        <!-- Colonne droite -->
        <Border Grid.Column="1" Background="White" Padding="20" BorderBrush="#bdc3c7" BorderThickness="1" CornerRadius="10" Margin="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <!-- Contenu principal -->
                    <RowDefinition Height="Auto" />
                    <!-- Boutons d'action -->
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <!-- Titre -->
                    <TextBlock Text="Localisation et Statut" FontSize="24" FontWeight="Bold" Foreground="#2c3e50" Margin="0,0,0,20" />

                    <!-- Section Adresse -->
                    <TextBlock Text="Adresse :" FontWeight="SemiBold" Margin="0,5" Foreground="#34495e" />
                    <TextBox Name="AddressTextBox" Margin="0,5" Height="30" Background="#ecf0f1" />

                    <TextBlock Text="Latitude :" FontWeight="SemiBold" Margin="0,5" Foreground="#34495e" />
                    <TextBox Name="LatitudeTextBox" Margin="0,5" Height="30" Background="#ecf0f1" IsEnabled="False"/>

                    <TextBlock Text="Longitude :" FontWeight="SemiBold" Margin="0,5" Foreground="#34495e" />
                    <TextBox Name="LongitudeTextBox" Margin="0,5" Height="30" Background="#ecf0f1" IsEnabled="False"/>

                    <!-- Section Statut -->
                    <TextBlock Text="Statut Actif :" FontWeight="SemiBold" Margin="0,5" Foreground="#34495e" />
                    <CheckBox Name="IsActiveCheckBox" Content="Actif" Margin="0,5" Foreground="#34495e" />

                    <TextBlock Text="Distance Max (km) :" FontWeight="SemiBold" Margin="0,5" Foreground="#34495e" />
                    <TextBox Name="MaxDistanceTextBox" Margin="0,5" Height="30" Background="#ecf0f1" />

                    <TextBlock Text="Type de Distance :" FontWeight="SemiBold" Margin="0,5" Foreground="#34495e" />
                    <ComboBox Name="DistanceTypeComboBox" Margin="0,5" Height="30" Background="#ecf0f1">
                        <ComboBoxItem Content="aerial" Tag="aerial" />
                        <ComboBoxItem Content="walking" Tag="walking" />
                        <ComboBoxItem Content="driving" Tag="driving" />
                    </ComboBox>

                    <TextBlock Text="Type d'Emploi :" FontWeight="SemiBold" Margin="0,5" Foreground="#34495e" />
                    <ComboBox Name="JobTypeComboBox" Margin="0,5" Height="30" Background="#ecf0f1">
                        <ComboBoxItem Content="Volunteer" Tag="Volunteer" />
                        <ComboBoxItem Content="Director" Tag="Director" />
                    </ComboBox>
                </StackPanel>

                <!-- Boutons d'Action -->
                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                    <Button Name="DeleteButton" Content="Supprimer" Width="120" Height="40" Margin="10,0,0,0" Background="#e74c3c"
        Foreground="White" FontWeight="Bold" Click="DeleteButton_Click"
        Visibility="{Binding IsDeleteButtonVisible}" />

                    <Button Content="Annuler" Width="120" Height="40" Margin="10,0,0,0" Background="#e74c3c"
                            Foreground="White" FontWeight="Bold" Click="CancelButton_Click" />
                    <Button Name="SaveButton" Content="Sauvegarder" Width="120" Height="40" Margin="10,0,0,0" Background="#2ecc71"
        Foreground="White" FontWeight="Bold" Click="SaveButton_Click" />

                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
