<Window x:Class="PL.Volunteer.VolunteerDetails"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Détails du Volontaire" Height="600" Width="500" Background="#f5f5f5">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Titre -->
        <TextBlock Grid.Row="0" Text="Détails du Volontaire" FontSize="24" FontWeight="Bold"
                   Foreground="#333" HorizontalAlignment="Center" Margin="0,10" />

        <!-- Contenu Principal -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="10">
                <!-- Section Identité -->
                <GroupBox Header="Identité" Margin="0,10" Padding="10">
                    <StackPanel>
                        <TextBlock Text="ID :" Margin="0,5"/>
                        <TextBox Name="IdTextBox" Margin="0,5" Height="30" IsEnabled="False" />

                        <TextBlock Text="Nom :" Margin="0,5"/>
                        <TextBox Name="NameTextBox" Margin="0,5" Height="30"/>

                        <TextBlock Text="Mot de passe :" Margin="0,5"/>
                        <Grid>
                            <PasswordBox Name="PasswordBox" Visibility="Visible" Margin="0,0,40,0" Height="30" />
                            <TextBox Name="PasswordTextBox" Visibility="Collapsed" Margin="0,0,40,0" Height="30" />
                            <Button Content="👁️" Width="30" Height="30" HorizontalAlignment="Right"
                                    Click="TogglePasswordVisibility_Click"/>
                        </Grid>

                        <TextBlock Text="Téléphone :" Margin="0,5"/>
                        <TextBox Name="PhoneTextBox" Margin="0,5" Height="30"/>

                        <TextBlock Text="Email :" Margin="0,5"/>
                        <TextBox Name="MailTextBox" Margin="0,5" Height="30"/>
                    </StackPanel>
                </GroupBox>

                <!-- Section Adresse -->
                <GroupBox Header="Localisation" Margin="0,10" Padding="10">
                    <StackPanel>
                        <TextBlock Text="Adresse :" Margin="0,5"/>
                        <TextBox Name="AddressTextBox" Margin="0,5" Height="30" />

                        <TextBlock Text="Latitude :" Margin="0,5"/>
                        <TextBox Name="LatitudeTextBox" Margin="0,5" Height="30" />

                        <TextBlock Text="Longitude :" Margin="0,5"/>
                        <TextBox Name="LongitudeTextBox" Margin="0,5" Height="30" />
                    </StackPanel>
                </GroupBox>

                <!-- Section Détails supplémentaires -->
                <GroupBox Header="Détails supplémentaires" Margin="0,10" Padding="10">
                    <StackPanel>
                        <TextBlock Text="Statut Actif :" Margin="0,5"/>
                        <CheckBox Name="IsActiveCheckBox" Content="Actif" Margin="0,5"/>

                        <TextBlock Text="Distance Max (km) :" Margin="0,5"/>
                        <TextBox Name="MaxDistanceTextBox" Margin="0,5" Height="30"/>

                        <TextBlock Text="Type de Distance :" Margin="0,5"/>
                        <ComboBox Name="DistanceTypeComboBox" Margin="0,5" Height="30">
                            <ComboBoxItem Content="Aérien" Tag="aerial"/>
                            <ComboBoxItem Content="À pied" Tag="walking"/>
                            <ComboBoxItem Content="En voiture" Tag="driving"/>
                        </ComboBox>

                        <TextBlock Text="Type d'Emploi :" Margin="0,5"/>
                        <ComboBox Name="JobTypeComboBox" Margin="0,5" Height="30">
                            <ComboBoxItem Content="Bénévole" Tag="Volunteer"/>
                            <ComboBoxItem Content="Directeur" Tag="Director"/>
                        </ComboBox>
                    </StackPanel>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>

        <!-- Boutons Actions -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="10">
            <Button Content="Annuler" Width="100" Height="40" Margin="5"
                    Background="#e74c3c" Foreground="White" FontWeight="Bold" 
                    Click="CancelButton_Click"/>
            <Button Name="SaveUpdateButton" Content="Sauvegarder" Width="100" Height="40" Margin="5"
                    Background="#2ecc71" Foreground="White" FontWeight="Bold"
                    Click="SaveButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
