<Window x:Class="PL.Call.CallInListWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Liste des Appels" Height="600" Width="800" Background="#f5f5f5">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Titre et Barre de Recherche -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Liste des Appels" FontSize="24" FontWeight="Bold" Foreground="#333"
                       VerticalAlignment="Center" Margin="10,0" />
            <TextBox Name="SearchTextBox" Width="300" Height="30" Margin="20,0,0,0"
                     HorizontalAlignment="Left" VerticalAlignment="Center"
                     TextChanged="SearchTextBox_TextChanged" />
        </StackPanel>

        <!-- Tableau des Appels -->
        <DataGrid Name="CallDataGrid" AutoGenerateColumns="False" CanUserAddRows="False"
                  IsReadOnly="True" SelectionMode="Single" Margin="0,10,0,10">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="100" />
                <DataGridTextColumn Header="ID Appel" Binding="{Binding callId}" Width="100" />
                <DataGridTextColumn Header="Type d'Appel" Binding="{Binding callType}" Width="150" />
                <DataGridTextColumn Header="Heure de Début" Binding="{Binding startingTime}" Width="200" />
                <DataGridTextColumn Header="Temps Restant" Binding="{Binding remainingTime}" Width="150" />
                <DataGridTextColumn Header="Dernier Volontaire" Binding="{Binding LastVolunteerName}" Width="200" />
                <DataGridTextColumn Header="Durée" Binding="{Binding duration}" Width="150" />
                <DataGridTextColumn Header="Statut" Binding="{Binding Status}" Width="100" />
                <DataGridTextColumn Header="Total des Affectations" Binding="{Binding TotalAssignmentAllocations}" Width="150" />
            </DataGrid.Columns>
        </DataGrid>

        <!-- Boutons d'Action -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10">
            <Button Content="Ajouter" Width="100" Height="40" Margin="5"
                    Background="#2ecc71" Foreground="White" FontWeight="Bold"
                    Click="AddCall_Click" />
            <Button Content="Rafraîchir" Width="100" Height="40" Margin="5"
                    Background="#3498db" Foreground="White" FontWeight="Bold"
                    Click="RefreshButton_Click" />
        </StackPanel>
    </Grid>
</Window>
