<Window x:Class="PL.Call.CallDetails"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Call Details" WindowState="Maximized" Background="#f5f5f5">
    <Grid>
        <!-- Fond avec un dégradé sobre -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#dfe6e9" Offset="0" />
                <GradientStop Color="#b2bec3" Offset="1" />
            </LinearGradientBrush>
        </Grid.Background>

        <!-- ScrollViewer pour permettre le défilement -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Grid>
                <Border Width="600" Background="White" CornerRadius="10"
                        Padding="30" BorderBrush="#dcdde1" BorderThickness="1"
                        HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,30">
                    <StackPanel Margin="10">
                        <!-- Titre -->
                        <TextBlock Text="Détails de l'Appel" FontSize="28" FontWeight="Bold" Foreground="#2c3e50" 
                                   HorizontalAlignment="Center" Margin="0,0,0,20" />

                        <!-- Call Type -->
                        <TextBlock Text="Type d'Appel :" FontWeight="SemiBold" Margin="0,10,0,5" Foreground="#2d3436" />
                        <ComboBox Name="CallTypeComboBox" Margin="0,5,0,10" Height="40" Background="#ecf0f1" FontSize="16" />

                        <!-- Description -->
                        <TextBlock Text="Description :" FontWeight="SemiBold" Margin="0,10,0,5" Foreground="#2d3436" />
                        <TextBox Name="DescriptionTextBox" Margin="0,5,0,10" Height="40" Background="#ecf0f1" FontSize="16" />

                        <!-- Address -->
                        <TextBlock Text="Adresse :" FontWeight="SemiBold" Margin="0,10,0,5" Foreground="#2d3436" />
                        <TextBox Name="AddressTextBox" Margin="0,5,0,10" Height="40" Background="#ecf0f1" FontSize="16" />

                        <!-- Latitude and Longitude -->
                        <TextBlock Text="Latitude et Longitude :" FontWeight="SemiBold" Margin="0,10,0,5" Foreground="#2d3436" />
                        <StackPanel Orientation="Horizontal" Margin="0,5,0,10">
                            <TextBox Name="LatitudeTextBox" Width="120" Height="40" Background="#ecf0f1" FontSize="16" Margin="0,0,10,0" IsReadOnly="True" />
                            <TextBox Name="LongitudeTextBox" Width="120" Height="40" Background="#ecf0f1" FontSize="16" IsReadOnly="True"/>
                        </StackPanel>

                        <!-- Created -->
                        <TextBlock Text="Créé le :" FontWeight="SemiBold" Margin="0,10,0,5" Foreground="#2d3436" />
                        <DatePicker Name="CreatedDatePicker" Margin="0,5,0,10" Height="40" FontSize="16" />

                        <!-- Max End Treatment -->
                        <TextBlock Text="Date Limite de Traitement :" FontWeight="SemiBold" Margin="0,10,0,5" Foreground="#2d3436" />
                        <DatePicker Name="MaxEndTreatmentDatePicker" Margin="0,5,0,10" Height="40" FontSize="16" />

                        <!-- Status -->
                        <TextBlock Text="Statut :" FontWeight="SemiBold" Margin="0,10,0,5" Foreground="#2d3436" />
                        <ComboBox Name="StatusComboBox" Margin="0,5,0,10" Height="40" Background="#ecf0f1" FontSize="16" />

                        <!-- Call Assign In Lists -->
                        <TextBlock Text="Affectations :" FontWeight="SemiBold" Margin="0,10,0,5" Foreground="#2d3436" />
                        <ListBox Name="CallAssignInListsListBox" Height="100" BorderBrush="#bdc3c7" BorderThickness="1" Background="#ecf0f1" Margin="0,5,0,10" />

                        <!-- Boutons -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                            <Button Name="SaveButton" Content="Sauvegarder" Width="150" Height="50"
                                    Background="#74b9ff" Foreground="White" FontWeight="Bold" FontSize="16" Margin="10,0,0,0" />
                            <Button Name="CancelButton" Content="Annuler" Width="150" Height="50"
                                    Background="#e74c3c" Foreground="White" FontWeight="Bold" FontSize="16" Margin="10,0,0,0" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</Window>
