<Window x:Class="PL.Call.CallDetails"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:BO="clr-namespace:BO;assembly=BL"
        Title="Détails de l'Appel" WindowState="Maximized" Background="#f5f5f5">

    <Window.Resources>
        <!-- Remplit le ComboBox avec les valeurs de callType -->
        <ObjectDataProvider x:Key="CallTypeEnumProvider" MethodName="GetValues"
                            ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="BO:callType"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>

        <!-- Remplit le ComboBox avec les valeurs de Status -->
        <ObjectDataProvider x:Key="StatusEnumProvider" MethodName="GetValues"
                            ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="BO:Status"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>

        <!-- Remplit le ComboBox avec les valeurs de TypeOfEndTreatment -->
        <ObjectDataProvider x:Key="TypeOfEndTreatmentEnumProvider" MethodName="GetValues"
                            ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="BO:typeOfEndTreatment"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*" />
            <ColumnDefinition Width="1*" />
        </Grid.ColumnDefinitions>

        <!-- Colonne gauche -->
        <Border Grid.Column="0" Background="White" Padding="20" BorderBrush="#bdc3c7" BorderThickness="1" CornerRadius="10" Margin="10">
            <StackPanel>
                <TextBlock Text="Informations Générales" FontSize="24" FontWeight="Bold" Foreground="#2c3e50" Margin="0,0,0,20" />

                <TextBlock Text="ID :" FontWeight="SemiBold" Margin="0,5" Foreground="#34495e" />
                <TextBox Name="IdTextBox" Margin="0,5" Height="30" IsEnabled="False" Background="#ecf0f1" />

                <TextBlock Text="Type d'Appel :" FontWeight="SemiBold" Margin="0,5" Foreground="#34495e" />
                <ComboBox Name="CallTypeComboBox" Margin="0,5" Height="30" Background="#ecf0f1"
                          ItemsSource="{Binding Source={StaticResource CallTypeEnumProvider}}"/>

                <TextBlock Text="Description :" FontWeight="SemiBold" Margin="0,5" Foreground="#34495e" />
                <TextBox Name="DescriptionTextBox" Margin="0,5" Height="30" Background="#ecf0f1" />

                <TextBlock Text="Adresse :" FontWeight="SemiBold" Margin="0,5" Foreground="#34495e" />
                <TextBox Name="AddressTextBox" Margin="0,5" Height="30" Background="#ecf0f1" />

                <TextBlock Text="Créé le :" FontWeight="SemiBold" Margin="0,5" Foreground="#34495e" />
                <TextBox Name="CreatedDateTextBox" Margin="0,5" Height="30" IsEnabled="False" Background="#ecf0f1" />
            </StackPanel>
        </Border>

        <!-- Colonne droite -->
        <Border Grid.Column="1" Background="White" Padding="20" BorderBrush="#bdc3c7" BorderThickness="1" CornerRadius="10" Margin="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <TextBlock Text="Affectations" FontSize="24" FontWeight="Bold" Foreground="#2c3e50" Margin="0,0,0,20" />

                    <ListBox Name="CallAssignInListsListBox" Height="150" BorderBrush="#bdc3c7" BorderThickness="1" Background="#ecf0f1"
                             ItemsSource="{Binding CallAssignInLists}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="5" BorderBrush="#bdc3c7" BorderThickness="1" CornerRadius="5" Background="White">
                                    <StackPanel Margin="5">
                                        <TextBlock Text="{Binding volounteerName}" FontWeight="Bold" Foreground="#2c3e50"/>
                                        <TextBlock Text="{Binding volounteerId, StringFormat='ID: {0}'}" Foreground="#34495e"/>
                                        <TextBlock Text="{Binding startingTime, StringFormat='Début: {0:dd/MM/yyyy HH:mm}'}" Foreground="#34495e"/>
                                        <TextBlock Text="{Binding endingTime, StringFormat='Fin: {0:dd/MM/yyyy HH:mm}'}" Foreground="#e74c3c"/>

                                        <TextBlock Text="Type de fin de traitement :" FontWeight="SemiBold" Foreground="#2c3e50"/>
                                        <ComboBox ItemsSource="{Binding Source={StaticResource TypeOfEndTreatmentEnumProvider}}"
                                                  SelectedItem="{Binding TypeOfEndTreatment, Mode=TwoWay}"
                                                  Background="#ecf0f1"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
