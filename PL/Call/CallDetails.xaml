<Window x:Class="PL.Call.CallDetails"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:BO="clr-namespace:BO;assembly=BL"
        Title="Détails de l'Appel" WindowState="Maximized" Background="#f5f5f5">

    <Window.Resources>
        <ObjectDataProvider x:Key="CallTypeEnumProvider" MethodName="GetValues"
                            ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="BO:callType"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>

        <ObjectDataProvider x:Key="StatusEnumProvider" MethodName="GetValues"
                            ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="BO:Status"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>

        <ObjectDataProvider x:Key="TypeOfEndTreatmentEnumProvider" MethodName="GetValues"
                            ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="BO:typeOfEndTreatment"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*" />
            <ColumnDefinition Width="1*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0" Grid.Column="0" Background="White" Padding="20" BorderBrush="#bdc3c7" BorderThickness="1" CornerRadius="10" Margin="10">
            <StackPanel>
                <TextBlock Text="Informations Générales" FontSize="26" FontWeight="Bold" Foreground="#2c3e50" Margin="0,0,0,20" />
                <TextBlock Text="ID :" FontWeight="SemiBold" Margin="0,10" Foreground="#34495e" />
                <TextBox Name="IdTextBox" Margin="0,5" Height="35" IsEnabled="False" Background="#ecf0f1" />

                <TextBlock Text="Type d'Appel :" FontWeight="SemiBold" Margin="0,10" Foreground="#34495e" />
                <ComboBox Name="CallTypeComboBox" Margin="0,5" Height="35" Background="#ecf0f1"
                          ItemsSource="{Binding Source={StaticResource CallTypeEnumProvider}}" />

                <TextBlock Text="Description :" FontWeight="SemiBold" Margin="0,10" Foreground="#34495e" />
                <TextBox Name="DescriptionTextBox" Margin="0,5" Height="35" Background="#ecf0f1" />

                <TextBlock Text="Adresse :" FontWeight="SemiBold" Margin="0,10" Foreground="#34495e" />
                <TextBox Name="AddressTextBox" Margin="0,5" Height="35" Background="#ecf0f1" />

                <TextBlock Text="Latitude :" FontWeight="SemiBold" Margin="0,10" Foreground="#34495e" />
                <TextBox Name="LatitudeTextBox" Margin="0,5" Height="35" IsEnabled="False" Background="#ecf0f1" />

                <TextBlock Text="Longitude :" FontWeight="SemiBold" Margin="0,10" Foreground="#34495e" />
                <TextBox Name="LongitudeTextBox" Margin="0,5" Height="35" IsEnabled="False" Background="#ecf0f1" />

                <TextBlock Text="Créé le :" FontWeight="SemiBold" Margin="0,10" Foreground="#34495e" />
                <TextBox Name="CreatedDateTextBox" Margin="0,5" Height="35" IsEnabled="False" Background="#ecf0f1" />

                <TextBlock Text="Max Fin de Traitement :" FontWeight="SemiBold" Margin="0,10" Foreground="#34495e" />
                <DatePicker Name="MaxEndTreatmentTextBox" Margin="0,5" Height="35" Background="#ecf0f1" />


                <TextBlock Text="Statut :" FontWeight="SemiBold" Margin="0,10" Foreground="#34495e" />
                <ComboBox Name="StatusComboBox" Margin="0,5" Height="35" Background="#ecf0f1"
                          ItemsSource="{Binding Source={StaticResource StatusEnumProvider}}" />
            </StackPanel>
        </Border>

        <Border Grid.Row="0" Grid.Column="1" Background="White" Padding="20" BorderBrush="#bdc3c7" BorderThickness="1" CornerRadius="10" Margin="10">
            <StackPanel>
                <TextBlock Text="Affectations" FontSize="26" FontWeight="Bold" Foreground="#2c3e50" Margin="0,0,0,20" />
                <ListBox Name="CallAssignInListsListBox" BorderBrush="#bdc3c7" BorderThickness="1" Background="#ecf0f1"
                         ItemsSource="{Binding CallAssignInLists}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="15" BorderBrush="#bdc3c7" BorderThickness="1" CornerRadius="5" Background="White"
                                    HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                                <Grid Margin="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2.5*" />
                                        <ColumnDefinition Width="1.5*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="10">
                                        <TextBlock Text="{Binding volunteerName}" FontSize="20" FontWeight="Bold" Foreground="#2c3e50" Margin="0,0,0,5"/>
                                        <TextBlock Text="{Binding volunteerId, StringFormat='ID: {0}'}" Foreground="#34495e" FontSize="16" Margin="0,0,0,5"/>
                                        <TextBlock Text="{Binding startingTime, StringFormat='Début: {0:dd/MM/yyyy HH:mm}'}" Foreground="#34495e" FontSize="16" Margin="0,0,0,5"/>
                                        <TextBlock Text="{Binding endingTime, StringFormat='Fin: {0:dd/MM/yyyy HH:mm}'}" Foreground="#e74c3c" FontSize="16" Margin="0,0,0,5"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Margin="10" VerticalAlignment="Center">
                                        <TextBlock Text="Type de fin de traitement :" FontWeight="SemiBold" Foreground="#2c3e50" FontSize="16" Margin="0,0,0,5"/>
                                        <ComboBox ItemsSource="{Binding Source={StaticResource TypeOfEndTreatmentEnumProvider}}"
                                                  SelectedItem="{Binding TypeOfEndTreatment, Mode=TwoWay}" Background="#ecf0f1"
                                                  HorizontalAlignment="Stretch" Height="35"
                                                  SelectionChanged="ComboBox_SelectionChanged"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </StackPanel>
        </Border>

        <Button x:Name="SaveButton" Grid.Row="1" Grid.Column="1" Content="Ajouter" Width="140" Height="50" Background="#27ae60" Foreground="White"
                FontSize="18" FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="20"
                Click="AddButton_Click"/>
    </Grid>
</Window>