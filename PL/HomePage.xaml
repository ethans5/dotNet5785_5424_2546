<Window x:Class="PL.HomePage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Page d'Accueil"
        WindowState="Maximized"
        Background="#FAFAFA">

    <!-- Définition des styles -->
    <Window.Resources>
        <!-- Style pour les boutons principaux -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#2196F3"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="10"/>
            <!-- Ajout de marge par défaut -->
            <Setter Property="BorderBrush" Value="#1E88E5"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1E88E5"/>
                    <Setter Property="BorderBrush" Value="#1565C0"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#1565C0"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Style pour les boutons secondaires -->
        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#EEEEEE"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="BorderBrush" Value="#BDBDBD"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E0E0E0"/>
                    <Setter Property="BorderBrush" Value="#9E9E9E"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#BDBDBD"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Style pour les boutons d'avertissement (danger) -->
        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#F44336"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#D32F2F"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E53935"/>
                    <Setter Property="BorderBrush" Value="#C62828"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#B71C1C"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- En-tête -->
        <Border Background="#2196F3" Height="70" VerticalAlignment="Top">
            <TextBlock Text="Gestion du Système" FontSize="28" FontWeight="Bold" Foreground="White"
                       VerticalAlignment="Center" HorizontalAlignment="Center" />
        </Border>

        <!-- Contenu principal -->
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <!-- Horloge -->
            <Border Background="White" CornerRadius="10" Padding="20" Margin="10" Style="{StaticResource DropShadowEffect}">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Name="ClockText" Text="Horloge : 00:00:00" FontSize="48" FontWeight="Bold"
                               Foreground="#333" HorizontalAlignment="Center" />
                    <TextBlock Text="Temps actuel du système" FontSize="16" Foreground="#666"
                               HorizontalAlignment="Center" />
                </StackPanel>
            </Border>

            <!-- Boutons d'horloge -->
            <WrapPanel HorizontalAlignment="Center">
                <Button Content="+1 Minute" Width="120" Height="40" Style="{StaticResource PrimaryButton}" Click="AddMinute_Click" />
                <Button Content="+1 Heure" Width="120" Height="40" Style="{StaticResource PrimaryButton}" Click="AddHour_Click" />
                <Button Content="+1 Jour" Width="120" Height="40" Style="{StaticResource PrimaryButton}" Click="AddDay_Click" />
                <Button Content="+1 Mois" Width="120" Height="40" Style="{StaticResource PrimaryButton}" Click="AddMonth_Click" />
                <Button Content="+1 Année" Width="120" Height="40" Style="{StaticResource PrimaryButton}" Click="AddYear_Click" />
            </WrapPanel>

             <!--Zone Variables de Configuration--> 
            <Border Background="White" CornerRadius="10" Padding="20" Margin="10" Style="{StaticResource DropShadowEffect}">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="Update Risk Range" FontSize="20" FontWeight="Bold"
                               Foreground="#333" Margin="0,0,0,10" HorizontalAlignment="Center" />

                     <!--Numeric UpDown Simulation--> 
                    <DockPanel HorizontalAlignment="Center">
                        <TextBox x:Name="riskTxtBox" Text="{Binding ConfigValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Width="150" Height="30" Margin="5,0" HorizontalAlignment="Center"
                                 VerticalContentAlignment="Center" TextAlignment="Center"
                                 PreviewTextInput="NumericOnlyTextBox_PreviewTextInput"  />
                    </DockPanel>

                     <!--Bouton pour mettre à jour la base de données--> 
                    <Button Content="Mettre à jour" Width="150" Height="40" Style="{StaticResource PrimaryButton}"
                            Click="UpdateConfigValue_Click" HorizontalAlignment="Center" />
                </StackPanel>
            </Border>


       


                <!-- Boutons de gestion -->
            <WrapPanel HorizontalAlignment="Center" Margin="10">
                <Button Content="Gérer Volontaires" Width="200" Height="50" Style="{StaticResource SecondaryButton}" Click="ManageVolunteers_Click" Margin="10" />
                <Button Content="Gérer Appels" Width="200" Height="50" Style="{StaticResource SecondaryButton}" Click="ManageCalls_Click" Margin="10" />
                <Button Content="Initialiser DB" Width="200" Height="50" Style="{StaticResource SecondaryButton}" Click="InitializeDB_Click" Margin="10" />
                <Button Content="Réinitialiser DB" Width="200" Height="50" Style="{StaticResource SecondaryButton}" Click="ResetDB_Click" Margin="10" />
            </WrapPanel>
        </StackPanel>

        <!-- Bouton Quitter -->
        <Button Content="Quitter" Width="100" Height="40" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                Margin="10" Style="{StaticResource DangerButton}" Click="ExitApp_Click" />
    </Grid>
</Window>
