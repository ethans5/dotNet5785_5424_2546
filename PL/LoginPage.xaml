<Window x:Class="PL.LoginPage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Connexion" WindowState="Maximized" Background="#f5f5f5">
    <Grid>
        <!-- Fond avec un dégradé -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#3498db" Offset="0" />
                <GradientStop Color="#2ecc71" Offset="1" />
            </LinearGradientBrush>
        </Grid.Background>

        <!-- Contenu principal centré -->
        <Grid>
            <Border Width="400" Height="500" Background="White" CornerRadius="10"
                    Padding="30" BorderBrush="#bdc3c7" BorderThickness="1">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <!-- Logo ou Titre -->
                    <TextBlock Text="Bienvenue" FontSize="36" FontWeight="Bold" Foreground="#2c3e50" 
                               HorizontalAlignment="Center" Margin="0,0,0,20" />

                    <!-- Instructions -->
                    <TextBlock Text="Veuillez vous connecter pour continuer" FontSize="16" Foreground="#7f8c8d" 
                               HorizontalAlignment="Center" Margin="0,0,0,20" />

                    <!-- ID -->
                    <TextBlock Text="Identifiant (ID) :" FontWeight="SemiBold" Margin="0,5" Foreground="#34495e" />
                    <TextBox Name="IdTextBox" Margin="0,5" Height="40" Background="#ecf0f1" 
                             FontSize="16" Padding="5" />

                    <!-- Mot de passe -->
                    <TextBlock Text="Mot de Passe :" FontWeight="SemiBold" Margin="0,5,0,5" Foreground="#34495e" />
                    <PasswordBox Name="PasswordBox" Margin="0,5" Height="40" Background="#ecf0f1" 
                                 FontSize="16" Padding="5" />

                    <!-- Bouton Connexion -->
                    <Button Content="Se connecter" HorizontalAlignment="Stretch" Height="50" Background="#2ecc71" 
                            Foreground="White" FontWeight="Bold" FontSize="16" Margin="0,20,0,0"
                            Click="LoginButton_Click" />

                    <!-- Ligne séparatrice -->
                    <Rectangle Height="2" Fill="#bdc3c7" Margin="0,20,0,20" />

                    <!-- Mot de passe oublié -->
                    <Button Content="Mot de passe oublié ?" HorizontalAlignment="Center" Background="Transparent"
                            Foreground="#3498db" BorderThickness="0" FontWeight="Bold"
                            Click="ForgotPasswordButton_Click" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
